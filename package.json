{
  "name": "zeek-mcp",
  "version": "3.0.0",
  "description": "MCP server for Zeek network analysis framework - query and analyze Zeek logs via AI",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "zeek-mcp": "dist/index.js"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit",
    "generate-logs": "tsx scripts/generate-zeek-logs.ts",
    "prepublishOnly": "npm run typecheck && npm test && npm run build",
    "typecheck": "tsc --noEmit"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "author": "Solomon Neas <me@solomonneas.dev>",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "tsup": "^8.4.0",
    "tsx": "^4.19.3",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ]
}
